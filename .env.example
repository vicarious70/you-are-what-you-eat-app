# Health DNA backend (Supabase) — copy to .env and fill in.
# In Vercel, set these as Environment Variables instead of committing them.

# From Supabase: Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Service role key: SERVER ONLY. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Anon/public key: safe for the browser client (used with a logged-in session).
SUPABASE_ANON_KEY=your_anon_public_key

# Dev only: trust an `x-user-id` header (or ?userId=) without a Supabase JWT.
# Leave unset/false in production.
ALLOW_DEV_USER=false

# Meal-photo vision (existing feature, optional for the engine)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
